CREATE OR REPLACE PROCEDURE automate_monthly_payroll AS
    v_base_salary  NUMBER;
    v_bonus        NUMBER;
    v_deductions   NUMBER;
    v_net_sal      NUMBER;
    v_present_days NUMBER;
    v_pay_month    NUMBER;
    v_pay_year     NUMBER;
    v_msg          VARCHAR2(200);
BEGIN
    DBMS_OUTPUT.PUT_LINE('--- Starting One-Time Payroll Calculation Run ---');

    FOR emp_rec IN (SELECT emp_id, emp_name FROM emp) LOOP
        
        v_base_salary  := NULL;
        v_bonus        := NULL;
        v_deductions   := NULL;
        v_net_sal      := NULL;
        v_present_days := NULL;
        v_pay_month    := NULL;
        v_pay_year     := NULL;
        v_msg          := NULL;

        BEGIN
            manage_payroll(
                payroll_id_1   => NULL,
                emp_id_1       => emp_rec.emp_id,
                base_salary_1  => v_base_salary,
                bonus_1        => v_bonus,
                deductions_1   => v_deductions,
                net_sal_1      => v_net_sal,
                present_days_1 => v_present_days,
                pay_month_1    => v_pay_month,
                pay_year_1     => v_pay_year,
                msg            => v_msg,
                action         => 'i'
            );

            DBMS_OUTPUT.PUT_LINE('Emp ID: ' || emp_rec.emp_id || ' (' || emp_rec.emp_name || ') | ' || v_msg || ' | Net Pay: ' || v_net_sal);

        EXCEPTION
            WHEN NO_DATA_FOUND THEN
                DBMS_OUTPUT.PUT_LINE('Warning: Skipping Emp ID ' || emp_rec.emp_id || '. No tracking found in Attendance table.');
            WHEN OTHERS THEN
                DBMS_OUTPUT.PUT_LINE('Error on Emp ID ' || emp_rec.emp_id || ': ' || SQLERRM);
        END;
        
    END LOOP;
    
    DBMS_OUTPUT.PUT_LINE('--- One-Time Payroll Run Successfully Terminated ---');
END;

