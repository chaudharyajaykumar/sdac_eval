
-- emp
create table emp(emp_id int generated by default as identity primary key,emp_name varchar(50),designation varchar(50),salary number check (salary >0),hire_date date default sysdate);

-- attendance
create table attendance(att_id int generated by default as identity primary key,emp_id number,present_days number check (present_days between 0 and 31) ,month number  check ( month between 1 and 12 ),year number check (year>2000) );
alter table attendance add constraint emp_att_key foreign key (emp_id) references emp(emp_id);

-- payroll
create table payroll(payroll_id int generated by default as identity primary key,emp_id number,base_salary number,bonus number,deductions number,net_sal number,pay_month number,pay_year number );
alter table payroll add constraint emp_pay_key foreign key (emp_id) references emp(emp_id);

--backup_payroll
create table backup_payroll(backup_id int generated by default as identity primary key,payroll_id int ,emp_id number,base_salary number,bonus number,deductions number,net_sal number,pay_month number,pay_year number,operation varchar(30),operation_date date default sysdate);




-- trigger on payroll 

-- insert
create or replace trigger t_insert_payroll
after insert on payroll
for each row
begin  
  insert into backup_payroll(payroll_id,emp_id,base_salary,bonus,deductions,net_sal,pay_month,pay_year,operation ) values (:new.payroll_id,:new.emp_id,:new.base_salary,:new.bonus,:new.deductions,:new.net_sal,:new.pay_month,:new.pay_year,'insert' );
end;


--update
create or replace trigger t_update_payroll
before update on payroll
for each row
declare
    v_present_days number;
begin  

   begin
        select present_days into v_present_days 
        from attendance 
        where emp_id = :old.emp_id 
          and month  = :new.pay_month 
          and year   = :new.pay_year;
    exception
        when no_data_found then
            v_present_days := 25; -- Fallback default if no record exists
    end;


if v_present_days < 15 then 
        :new.deductions := 1000;
        :new.net_sal    := :old.base_salary + :new.bonus - 1000;
    end if;


insert into backup_payroll(payroll_id,emp_id,base_salary,bonus,deductions,net_sal,pay_month,pay_year,operation ) values (:old.payroll_id,:old.emp_id,:old.base_salary,:new.bonus,:new.deductions,:new.net_sal,:new.pay_month,:new.pay_year,'update' );

end;




--delete
create or replace trigger t_delete_payroll
before delete on payroll
for each row
begin  
  insert into backup_payroll(payroll_id,emp_id,base_salary,bonus,deductions,net_sal,pay_month,pay_year,operation ) values (:old.payroll_id,:old.emp_id,:old.base_salary,:old.bonus,:old.deductions,:old.net_sal,:old.pay_month,:old.pay_year,'delete' );
end;



-- manage_payroll

create or replace procedure manage_payroll(payroll_id_1 number default null,emp_id_1 number,base_salary_1 in out  number,bonus_1  in out number,deductions_1  in out number,net_sal_1 in out number ,present_days_1  in out number,pay_month_1  in out number,pay_year_1  in out number,msg out varchar2,action varchar2  )
as 
begin

if action not in ('i','u','d','s') then
  msg :='enter valid action (i,u,d,s)';
  return ;
end if;

if (action = 'i') then 
  select salary into base_salary_1 from emp where emp_id=emp_id_1;
  select present_days,month,year into present_days_1 ,pay_month_1 , pay_year_1 from attendance where emp_id =emp_id_1;

  if present_days_1 >25 then 
    bonus_1 :=1000;
  else
    bonus_1:=0;
  end if;

  if present_days_1 <20 then 
    deductions_1 :=500;
  else
    deductions_1:=0;
  end if;

  net_sal_1 := base_salary_1 -deductions_1+ bonus_1;

  insert into payroll(emp_id,base_salary,bonus,deductions,net_sal,pay_month,pay_year ) values (emp_id_1,base_salary_1,bonus_1,deductions_1,net_sal_1,pay_month_1,pay_year_1 );
  
end if;

if (action = 'u') then 

  update payroll set bonus =nvl(bonus_1,bonus),deductions=nvl(deductions_1,deductions),pay_month=nvl(pay_month_1,pay_month),pay_year=nvl(pay_year_1,pay_year),net_sal = base_salary + nvl(bonus_1, bonus) - nvl(deductions_1, deductions) where payroll_id=payroll_id_1;

end if;

if (action = 'd') then 
   delete from payroll where  payroll_id=payroll_id_1;
end if;

if (action = 's') then 
    if payroll_id_1 is not null then 
      for r in (SELECT * FROM payroll WHERE payroll_id = payroll_id_1 ) loop
      dbms_output.put_line('ID: ' || r.payroll_id || ' | Net: ' || r.net_sal);
     end loop;
    else
      FOR r IN (SELECT * FROM payroll) LOOP
                DBMS_OUTPUT.PUT_LINE('ID: ' || r.payroll_id || ' | Emp: ' || r.emp_id || ' | Net: ' || r.net_sal);
            END LOOP;
    end if;
end if;

msg := action || '  operation done';
end;






